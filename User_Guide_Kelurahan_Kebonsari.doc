<!-- LAMPIRAN -->
<!-- ================================================================ -->
<h1>Lampiran: Daftar Route Aplikasi</h1>

<table>
<tr><th>Method</th><th>URL</th><th>Nama Route</th><th>Keterangan</th></tr>

<tr><td>GET</td><td>/</td><td>index</td><td>Halaman utama publik</td></tr>
<tr><td>POST</td><td>/layanan</td><td>web.layanan.index</td><td>Daftar layanan (setelah isi data diri)</td></tr>
<tr><td>GET</td><td>/layanan/{sektor}</td><td>web.layanan.sektor</td><td>Layanan per kategori/sektor</td></tr>
<tr><td>GET</td><td>/layanan/detail/{id}</td><td>web.layanan.detail</td><td>Detail layanan publik</td></tr>
<tr><td>GET</td><td>/layanan/detail/{id}/klik_app</td><td>web.layanan.klik_app</td><td>Klik aplikasi eksternal</td></tr>
<tr><td>GET</td><td>/search-layanan</td><td>web.layanan.search</td><td>Pencarian layanan</td></tr>
<tr><td>GET</td><td>/video-proxy/{fileId}</td><td>video.proxy</td><td>Proxy streaming video Google Drive</td></tr>
<tr><td>GET</td><td>/informasi-umum</td><td>web.informasi_umum</td><td>Informasi umum dan agenda</td></tr>
<tr><td>GET</td><td>/informasi-umum/detail/{id}</td><td>web.informasi_umum.detail</td><td>Detail agenda publik</td></tr>
<tr><td>POST</td><td>/visitor/session/destroy</td><td>visitor.session.destroy</td><td>Hapus session visitor</td></tr>

<tr><td colspan="4" style="background:#E8F0FE; font-weight:bold;">Admin (perlu login)</td></tr>

<tr><td>GET</td><td>/dashboard</td><td>dashboard</td><td>Dashboard admin</td></tr>
<tr><td>GET</td><td>/dashboard/users</td><td>users.index</td><td>Daftar user</td></tr>
<tr><td>PATCH</td><td>/dashboard/users/{user}/role</td><td>users.update_role</td><td>Ubah role user</td></tr>
<tr><td>GET</td><td>/dashboard/layanan</td><td>layanan.index</td><td>Daftar layanan</td></tr>
<tr><td>GET</td><td>/dashboard/layanan/create</td><td>layanan.create</td><td>Form tambah layanan</td></tr>
<tr><td>POST</td><td>/dashboard/layanan</td><td>layanan.store</td><td>Simpan layanan baru</td></tr>
<tr><td>GET</td><td>/dashboard/layanan/{layanan}</td><td>layanan.show</td><td>Detail layanan</td></tr>
<tr><td>GET</td><td>/dashboard/layanan/{layanan}/edit</td><td>layanan.edit</td><td>Form edit layanan</td></tr>
<tr><td>PUT/PATCH</td><td>/dashboard/layanan/{layanan}</td><td>layanan.update</td><td>Update layanan</td></tr>
<tr><td>DELETE</td><td>/dashboard/layanan/{layanan}</td><td>layanan.destroy</td><td>Hapus layanan</td></tr>
<tr><td>GET</td><td>/dashboard/info</td><td>info.index</td><td>Edit info halaman</td></tr>
<tr><td>PUT</td><td>/dashboard/info/{info}</td><td>info.update</td><td>Simpan info halaman</td></tr>
<tr><td>GET</td><td>/dashboard/pengunjung</td><td>pengunjung.index</td><td>Data pengunjung</td></tr>
<tr><td>GET</td><td>/dashboard/pengunjung/export_excel/{bulan}/{tahun}</td><td>pengunjung.export_excel</td><td>Ekspor Excel pengunjung</td></tr>
<tr><td>GET</td><td>/dashboard/agenda</td><td>agenda.index</td><td>Daftar agenda</td></tr>
<tr><td>GET</td><td>/dashboard/agenda/create</td><td>agenda.create</td><td>Form tambah agenda</td></tr>
<tr><td>POST</td><td>/dashboard/agenda</td><td>agenda.store</td><td>Simpan agenda baru</td></tr>
<tr><td>GET</td><td>/dashboard/agenda/{agenda}</td><td>agenda.show</td><td>Detail agenda</td></tr>
<tr><td>GET</td><td>/dashboard/agenda/{agenda}/edit</td><td>agenda.edit</td><td>Form edit agenda</td></tr>
<tr><td>PUT/PATCH</td><td>/dashboard/agenda/{agenda}</td><td>agenda.update</td><td>Update agenda</td></tr>
<tr><td>DELETE</td><td>/dashboard/agenda/{agenda}</td><td>agenda.destroy</td><td>Hapus agenda</td></tr>
<tr><td>POST</td><td>/dashboard/agenda/upload_lampiran</td><td>agenda.upload_lampiran</td><td>Upload lampiran agenda</td></tr>
<tr><td>POST</td><td>/dashboard/agenda/update_lampiran</td><td>agenda.update_lampiran</td><td>Update lampiran agenda</td></tr>
<tr><td>GET</td><td>/dashboard/agenda/hapus_lampiran/{id_lampiran}</td><td>agenda.hapus_lampiran</td><td>Hapus lampiran agenda</td></tr>
</table>

